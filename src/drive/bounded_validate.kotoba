(ns drive.bounded-validate
  (:require [drive.bounded :as drive])
  (:export [valid?]))

(def parent-type [:option :keyword])
(def item-type
  [:record :drive/item
   [[:id :keyword] [:kind :keyword] [:parent [:alias parent-type]]]])
(def items-type [:map :keyword [:alias item-type]])
(def drive-type
  [:record :drive/drive
   [[:id :keyword] [:root :keyword] [:items [:alias items-type]]]])
(def item-option-type [:option [:alias item-type]])
(def entry-type [:vector [:keyword [:alias item-type]]])
(def entry-option-type [:option [:alias entry-type]])

(defn known-kind? [kind :keyword] :bool
  (if (= kind :folder) true
    (if (= kind :file) true false)))

(defn parent-chain-valid?
  [items [:alias items-type] root :keyword id :keyword fuel :i64] :bool
  (if (= fuel 0) false
    (match-option (typed-map-get items-type items id) item-option-type
      (none false)
      (some item
        (match-option (record-get item-type item :parent) parent-type
          (none (if (= id root) true false))
          (some parent-id
            (if (= id root) false
              (if (= parent-id id) false
                (match-option (typed-map-get items-type items parent-id) item-option-type
                  (none false)
                  (some parent
                    (if (= (record-get item-type parent :kind) :folder)
                      (parent-chain-valid? items root parent-id (- fuel 1))
                      false)))))))))))

(defn items-valid-loop
  [items [:alias items-type] root :keyword index :i64 count :i64] :bool
  (if (= index count) true
    (match-option (typed-map-entry-at items-type items index) entry-option-type
      (none false)
      (some entry
        (let [key (hetero-vector-at entry-type entry 0)
              item (hetero-vector-at entry-type entry 1)]
          (if (= key (record-get item-type item :id))
            (if (known-kind? (record-get item-type item :kind))
              (if (parent-chain-valid? items root key (+ count 1))
                (items-valid-loop items root (+ index 1) count)
                false)
              false)
            false))))))

(defn valid? [value [:alias drive-type]] :bool
  (let [items (record-get drive-type value :items)
        root (record-get drive-type value :root)
        count (typed-map-count items-type items)]
    (if (= count 0) false
      (if (< 8 count) false
        (match-option (typed-map-get items-type items root) item-option-type
          (none false)
          (some root-item
            (if (= (record-get item-type root-item :kind) :folder)
              (match-option (record-get item-type root-item :parent) parent-type
                (none (items-valid-loop items root 0 count))
                (some unexpected false))
              false)))))))
