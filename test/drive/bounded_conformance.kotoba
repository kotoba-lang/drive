(ns drive.bounded-conformance
  (:require [drive.bounded :as drive]
            [drive.bounded-validate :as validate])
  (:export [main]))

(def parent-type [:option :keyword])
(defn main [] :i64
  (let [base (drive/new-drive :gftd-drive :root)
        folder (drive/new-folder :docs (option-some-of parent-type :root))
        file (drive/new-file :intro :docs)
        valid-drive (drive/put-item (drive/put-item base folder) file)
        dangling (drive/put-item base (drive/new-file :lost :missing))
        file-parent (drive/put-item
                      (drive/put-item base (drive/new-file :plain :root))
                      (drive/new-file :nested :plain))
        self-cycle (drive/put-item base
                     (drive/new-folder :loop (option-some-of parent-type :loop)))
        cycle (drive/put-item
                (drive/put-item base
                  (drive/new-folder :a (option-some-of parent-type :b)))
                (drive/new-folder :b (option-some-of parent-type :a)))
        d01 (drive/put-item base (drive/new-file :f01 :root))
        d02 (drive/put-item d01 (drive/new-file :f02 :root))
        d03 (drive/put-item d02 (drive/new-file :f03 :root))
        d04 (drive/put-item d03 (drive/new-file :f04 :root))
        d05 (drive/put-item d04 (drive/new-file :f05 :root))
        d06 (drive/put-item d05 (drive/new-file :f06 :root))
        d07 (drive/put-item d06 (drive/new-file :f07 :root))
        d08 (drive/put-item d07 (drive/new-file :f08 :root))
        overflow d08]
    (if (validate/valid? valid-drive)
      (if (= 3 (drive/item-count valid-drive))
        (if (validate/valid? dangling) 3
          (if (validate/valid? file-parent) 4
            (if (validate/valid? self-cycle) 5
              (if (validate/valid? cycle) 6
                (if (validate/valid? overflow) 7
                  42)))))
        2)
      1)))
